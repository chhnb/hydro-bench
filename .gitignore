# Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# Virtualenvs
venv/
spmd-venv/
.venv/

# Build artifacts (compiled by setup.sh)
cuda_native_impl/F1_hydro_native_*
cuda_native_impl/F2_hydro_native_*
cuda_native_impl/hydro_native_benchmark
cuda_native_impl/fp32_src/hydro_native_benchmark
cuda_native_impl/*.original
cuda_native_impl/*.bak
cuda_native_impl/*_nofma
cuda_impl/F1_persistent_bench
cuda_impl/F2_persistent_bench
cuda_impl/hydro_persistent_bench
*.o
*.so
*.cubin

# Generated PTX / IR dumps (debug)
cuda_impl/*.ptx
data/**/*.ptx
data/**/*.json
/tmp/taichi_*

# Large mesh / dump data — fetch via separate data archive (see docs/DATA.md)
data/
cuda_native_impl/*_native_data/
**/native_dump*.bin
*.bin

# Test outputs — block raw per-(case, step) artifacts and bulky frame
# dumps; allow the curated summary text + NCU jsonl to be tracked so a
# reader can reproduce the headline numbers without re-running the matrix.
results/*.jsonl
results/*.txt
results/alignment/*.json
results/alignment/SUMMARY.md
results/alignment/native_outputs/
results/alignment/taichi_outputs/
results/alignment/diffs/
!results/.gitkeep
!results/performance_8case_summary.txt
!results/correctness_8case_summary.txt
!results/ncu_results.jsonl
!results/alignment/SUMMARY.md

# Editor / OS
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# NFS sillyrename artifacts (created when an NFS-backed file is unlinked
# while still open by another process); they disappear on their own and
# should never be tracked.
**/.nfs*
/venv

# Tool stubs
.codex

# RLCR loop state (created by humanize:start-rlcr-loop)
.humanize*
.local_venv/
